# ===== Environment =====
SUPPLY_OS_ENV=dev

# ===== Data backend =====
# "seed" (read from local CSVs) or "sheet" (Google Sheets, Phase 1.5)
SUPPLY_OS_DATA_BACKEND=seed
SUPPLY_OS_SEED_DIR=../docs/pita-supply-os-v1/seed

# ===== Google Sheets (only when SUPPLY_OS_DATA_BACKEND=sheet) =====
SUPPLY_OS_GOOGLE_SHEET_ID=
# Paste the full service-account JSON on a single line.
# Stored as SecretStr — never logged or echoed in error responses.
SUPPLY_OS_GOOGLE_SERVICE_ACCOUNT_JSON=
# CLI-safe alternative for hosts whose env handling mangles multi-line values
# (e.g. Railway `railway variables --set`): base64-encode the JSON —
#   base64 -i sa.json | tr -d '\n'
# Decoded at startup; preferred over the raw inline var, after the file path.
# Used by BOTH the Sheets backend and Drive (GR-01) via the shared resolver.
SUPPLY_OS_GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# ===== Google Drive (WZ goods-receipt photos, GR-01) =====
# Id of the "WZ Photos" Drive folder, shared with the service account as Editor.
# Empty => goods-receipt photo upload is disabled (the receipt still persists,
# flagged received_with_missing_wz). Reuses the service-account creds above.
SUPPLY_OS_GDRIVE_WZ_FOLDER_ID=

# ===== PostHog analytics =====
# Stored as SecretStr.
SUPPLY_OS_POSTHOG_API_KEY=
SUPPLY_OS_POSTHOG_HOST=https://eu.i.posthog.com

# ===== Auth (Bearer-token model, v0 pilot) =====
# Captain tokens: comma-separated LOCATION:token pairs.
# One shared code per location; every Captain at that location uses it.
# Example: WOLA:wolacode2026,KEN:kencode2026
#
# If empty, Captain auth is DISABLED and all requests default to
# location_id=WOLA with a startup warning. DO NOT leave empty in production.
SUPPLY_OS_CAPTAIN_TOKENS=

# Manager token: single shared code for the dispatcher.
# If empty, Manager auth is DISABLED with a startup warning.
# DO NOT leave empty in production.
SUPPLY_OS_MANAGER_TOKEN=

# ===== CORS — frontend origins allowed to call the API =====
# Comma-separated list. NEVER use "*" together with allow_credentials=True.
SUPPLY_OS_CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
