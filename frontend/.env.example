# Copy to .env.local for local dev.

# Backend base URL — DEV ONLY. In dev, leave default (local FastAPI on 8901).
# PROD does NOT use this: apiClient.ts hardcodes BASE_URL="" in production, so the
# browser calls same-origin /api/* and Vercel proxies it to the droplet backend.
# The backend host lives in ONE place — the rewrite destination in `vercel.json`.
# To repoint the backend (e.g. migrate off nip.io), edit vercel.json, NOT this var.
VITE_API_URL=http://localhost:8901

# Optional: PostHog analytics. Leave empty to disable.
# VITE_POSTHOG_KEY=phc_XXXXX
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
